# Copie estas variáveis para o Railway (Settings > Variables)

BOT_TOKEN=<token do seu bot Telegram>
CHAT_ID=<seu chat_id no Telegram>
GROQ_KEY=<sua chave da API Groq>
ANTHROPIC_KEY=<sua chave da API Anthropic>

GOOGLE_CLIENT_ID=<seu client_id do Google Cloud>
GOOGLE_CLIENT_SECRET=<seu client_secret do Google Cloud>
GOOGLE_REFRESH_TOKEN=<gerado pelo script gerar_token_google.py>
